{
  "appId": "com.phoebe.myos",
  "productName": "myOS",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*"
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "darkModeSupport": true,
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "identity": null,
    "icon": "build/icon.icns"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "npmRebuild": true
}
